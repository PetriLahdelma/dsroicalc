{
  "name": "@petrilahdelma/dsroicalc-roi-core",
  "version": "0.1.0",
  "description": "TypeScript ROI model for design system business cases.",
  "license": "MIT",
  "author": "Petri Lahdelma",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "design-system",
    "roi",
    "design-ops",
    "calculator",
    "business-case"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petrilahdelma/dsroicalc.git",
    "directory": "packages/roi-core"
  },
  "homepage": "https://github.com/petrilahdelma/dsroicalc#readme",
  "bugs": {
    "url": "https://github.com/petrilahdelma/dsroicalc/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsup": "^8.3.6",
    "typescript": "~5.8.3",
    "vitest": "^3.0.7"
  }
}
